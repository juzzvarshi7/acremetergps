<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        tools:ignore="ExtraText">

        <!-- 🔌 Device Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="8dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:padding="13dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/connectedDeviceText"
                    android:text="No device connected"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#59D91E"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/textViewStatus"
                    android:text="Status: Not Connected"
                    android:textSize="16sp"
                    android:textColor="#F06236"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/buttonGetRawData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get Raw Data" />
                <Button
                    android:id="@+id/buttonMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text= "view map" />


                <TextView
                    android:id="@+id/textViewRawData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Raw data will appear here"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#EEEEEE"
                    android:minHeight="100dp"/>



            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🔍 Connect Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:padding="10dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/editTextDeviceId"
                    android:hint="Enter Device ID"
                    android:minHeight="48dp"
                    android:inputType="text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/buttonConnectDevice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="Connect Device" />

                    <Button
                        android:id="@+id/buttonDisconnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Disconnect Device" />
                </LinearLayout>

                <TextView
                    android:id="@+id/summa"
                    android:text="Or connect with already paired devices"
                    android:textColor="#4285F4"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />


                <Button
                    android:id="@+id/buttonScanBluetooth"
                    android:text="Paired Devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 📈 Live Data -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textViewData"
                    android:text="Real-time Data Appears Here"
                    android:textColor="#FF5722"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="180dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🛠️ Device Config Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_gravity="center"
            android:layout_height="55dp"
            android:elevation="4dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:padding="8dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <Button
                    android:id="@+id/buttonOpenDeviceConfig"
                    android:text="Open Device Config"
                    android:layout_width="match_parent"
                    android:layout_gravity="center_vertical"
                    android:layout_height="48dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="15dp"
            android:elevation="4dp"
            app:cardCornerRadius="14dp">
            <!-- 🗃️ Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnOpenGpsTracking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS Tracking"
                    android:layout_marginTop="1dp"
                    />

                <Button
                    android:id="@+id/Trip_Data"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Trip Data" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
