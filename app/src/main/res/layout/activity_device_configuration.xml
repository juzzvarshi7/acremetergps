<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Field Template -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Serial No"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etSlNo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:hint="Serial Number"
                android:inputType="text"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Site -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Site"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etSite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:hint="Site"
                android:inputType="text"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Repeat same pattern for all other fields -->

        <!-- Date/Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Date/Time"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etDateTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:hint="Date/Time"
                android:inputType="datetime"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Mobile Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etMobileNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:inputType="phone"
                android:text="Mobile Number"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Pressure Range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Pressure Range"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etPressureRange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:inputType="text"
                android:text="Pressure Range"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Flow Range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Flow Range"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etFlowRange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:inputType="text"
                android:text="Flow Range"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Tamper Type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Tamper Type"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etTamperType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:inputType="text"
                android:text="Tamper Type"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- SMS Alt Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="SMS Alt Time"
                android:textStyle="bold"
                android:textColor="#000fff" />

            <EditText
                android:id="@+id/etSmsAltTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:inputType="text"
                android:text="SMS Alt Time"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnEditConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Config"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Config"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
